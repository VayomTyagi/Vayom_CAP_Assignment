{
  "welcomeFile": "/purchasorder/index.html",
  "authenticationMethod": "route",
  "routes": [
    {
      "source": "^/purchasorder/(.*)$",
      "target": "$1",
      "localDir": "purchasorder",
      "authenticationType": "xsuaa"
    },
    {
      "source": "^/purchasing/(.*)$",
      "target": "/purchasing/$1",
      "destination": "srv-api",
      "authenticationType": "xsuaa",
      "csrfProtection": false
    },
    {
      "source": "^/orders/(.*)$",
      "target": "/orders/$1",
      "destination": "srv-api",
      "authenticationType": "xsuaa"
    },
    {
      "source": "^/odata/v4/admin/(.*)$",
      "target": "/odata/v4/admin/$1",
      "destination": "srv-api",
      "authenticationType": "xsuaa"
    },
    {
      "source": "^/analytics/(.*)$",
      "target": "/analytics/$1",
      "destination": "srv-api",
      "authenticationType": "xsuaa"
    },
    {
      "source": "^/(.*)$",
      "target": "$1",
      "destination": "srv-api",
      "authenticationType": "xsuaa",
      "csrfProtection": false
    }
  ]
}