{
  "name": "epm",
  "version": "1.0.0",
  "dependencies": {
    "@sap/cds": "^9",
    "@sap/xssec": "^4",
    "passport": "^0.7.0"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2.4"
  },
  "scripts": {
    "start": "cds-serve"
  },
  "private": true,
  "cds": {
    "requires": {
      "db": {
        "kind": "sqlite",
        "credentials": { "url": "db.sqlite" }
      },
      "auth": {
        "kind": "xsuaa",
        "[development]": {
          "kind": "mocked",
          "users": {
            "*": false,
            "alice": {
              "password": "alice",
              "roles": ["PurchaseManager", "Viewer"],
              "attr": { "Department": "Engineering" }
            },
            "bob": {
              "password": "bob",
              "roles": ["PurchaseManager", "Viewer"],
              "attr": { "Department": "Marketing" }
            },
            "carol": {
              "password": "carol",
              "roles": ["Viewer"]
            },
            "dave": {
              "password": "dave",
              "roles": ["Administrator", "PurchaseManager", "Viewer"]
            }
          }
        }
      }
    }
  }
}
